// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id
  name           String
  email          String    @unique
  emailVerified  Boolean
  image          String?
  createdAt      DateTime
  updatedAt      DateTime
  
  passwordHash   String?   @map("password_hash")
  role           String    @default("fleet_manager")
  failedAttempts Int       @default(0) @map("failed_attempts")
  locked         Boolean   @default(false)

  sessions       Session[]
  accounts       Account[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Vehicle {
  id              Int               @id @default(autoincrement())
  registrationNo  String            @unique @map("reg_no")
  name            String
  type            String
  capacityKg      Float             @map("capacity_kg")
  odometer        Float             @default(0)
  acquisitionCost Float             @default(0) @map("acquisition_cost")
  region          String            @default("Ahmedabad")
  status          String            @default("available") // 'available', 'on_trip', 'in_shop', 'retired'
  
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model Driver {
  id              Int      @id @default(autoincrement())
  name            String
  licenseNumber   String   @unique @map("license_no")
  category        String
  licenseExpiry   DateTime @map("license_expiry")
  contact         String   @default("")
  safetyScore     Int      @default(100) @map("safety_score")
  tripsCompleted  Int      @default(0) @map("trips_completed")
  status          String   @default("available") // 'available', 'on_trip', 'off_duty', 'suspended'

  trips           Trip[]

  @@map("drivers")
}

model Trip {
  id            Int       @id @default(autoincrement())
  code          String?   @unique
  source        String
  destination   String
  vehicleId     Int?      @map("vehicle_id")
  driverId      Int?      @map("driver_id")
  cargoKg       Float?    @map("cargo_kg")
  plannedKm     Float?    @map("planned_km")
  revenue       Float     @default(0)
  status        String    @default("draft") // 'draft', 'dispatched', 'completed', 'cancelled'
  note          String?
  startOdometer Float?    @map("start_odometer")
  endOdometer   Float?    @map("end_odometer")
  fuelLiters    Float?    @map("fuel_liters")
  createdAt     DateTime  @default(now()) @map("created_at")
  dispatchedAt  DateTime? @map("dispatched_at")
  completedAt   DateTime? @map("completed_at")

  vehicle       Vehicle?  @relation(fields: [vehicleId], references: [id])
  driver        Driver?   @relation(fields: [driverId], references: [id])
  expenses      Expense[]

  @@map("trips")
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int      @map("vehicle_id")
  serviceType String   @map("service_type")
  cost        Float    @default(0)
  serviceDate DateTime @map("service_date")
  status      String   @default("active") // 'active', 'completed'
  notes       String?

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_logs")
}

model Expense {
  id          Int      @id @default(autoincrement())
  type        String   // 'FUEL', 'TOLL', 'MAINTENANCE', 'OTHER'
  vehicleId   Int?     @map("vehicle_id")
  tripId      Int?     @map("trip_id")
  amount      Float
  date        DateTime
  liters      Float?   // Only used if type == 'FUEL'
  description String?

  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  trip        Trip?    @relation(fields: [tripId], references: [id])

  @@map("expenses")
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}
