# Vercel Postgres (Neon) — required for production API mode
# Get this from your Vercel project dashboard: Settings → Environment Variables
# Or from Neon dashboard after migration
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Vercel also auto-injects these env vars when Postgres is attached:
# POSTGRES_URL, POSTGRES_URL_NON_POOLING, etc.
