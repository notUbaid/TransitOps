# Next.js App configuration
NEXT_PUBLIC_APP_URL="https://your-production-url.vercel.app"

# Better Auth required variables
# Generate a secret by running: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secure-random-secret"
BETTER_AUTH_URL="https://your-production-url.vercel.app"

# Database Configuration (Turso SQLite)
# Since Vercel Serverless wipes out local SQLite files, we use Turso (Serverless SQLite).
# In your Turso dashboard, grab the database URL and the auth token.
DATABASE_URL="libsql://your-database-name-username.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"
